per_frame_init_1=`
    decay = 0.98;
`
per_frame_1=`
    q1 = time;
`
per_pixel_1=`
    // Audio-reactive pulse
    float moon_pulse = 1.0 + 0.1 * bass_att;

    // Dynamic drift
    float2 moon_center = float2(0.5 + 0.03 * sin(time * 0.4), 0.5 + 0.03 * cos(time * 0.3));

    // Crescent Moon
    // first circle (the main body of the moon)
    float moon_radius = 0.2 * moon_pulse;
    float moon_dist = distance(uv, moon_center);
    float moon_shape = smoothstep(moon_radius, moon_radius - 0.01, moon_dist);

    // second circle (the part we subtract to make the crescent)
    float cutout_radius = 0.18 * moon_pulse;
    float2 cutout_offset = float2(0.08 * moon_pulse, 0.0);
    float cutout_dist = distance(uv, moon_center + cutout_offset);
    float cutout_shape = smoothstep(cutout_radius, cutout_radius - 0.01, cutout_dist);

    // combine the shapes
    float final_moon = moon_shape - cutout_shape;

    // color the moon
    float3 moon_color = float3(0.9, 0.9, 0.7); // A pale yellow

    // set the final color
    ret = saturate(final_moon * moon_color);
`

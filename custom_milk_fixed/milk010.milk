MILKDROP_PRESET_VERSION=201
PSVERSION=3
PSVERSION_WARP=3
PSVERSION_COMP=3
[preset00]
fRating=5.000000
fGammaAdj=1.000
fDecay=0.950
fVideoEchoZoom=1.000
fVideoEchoAlpha=0.000
nVideoEchoOrientation=0
nWaveMode=0
bAdditiveWaves=0
bWaveDots=0
bWaveThick=0
bModWaveAlphaByVolume=0
bMaximizeWaveColor=0
bTexWrap=0
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=0
bDarken=0
bSolarize=0
bInvert=0
fWaveAlpha=0.001
fWaveScale=1.002
fWaveSmoothing=0.261
fWaveParam=0.000
fModWaveAlphaStart=0.500
fModWaveAlphaEnd=1.000
fWarpAnimSpeed=1.000
fWarpScale=1.331
fZoomExponent=1.0
fShader=0.0
zoom=1.0
rot=0.0
cx=0.5
cy=0.5
dx=0.0
dy=0.0
warp=1.0
sx=1.0
sy=1.0
wave_r=0.5
wave_g=0.5
wave_b=0.5
wave_x=0.5
wave_y=0.5
ob_size=0.01
ob_r=0.0
ob_g=0.0
ob_b=0.0
ob_a=1.0
ib_size=0.01
ib_r=0.0
ib_g=0.0
ib_b=0.0
ib_a=1.0
mv_x=64.0
mv_y=48.0
mv_dx=0.0
mv_dy=0.0
mv_l=0.9
mv_r=1.0
mv_g=1.0
mv_b=1.0
mv_a=0.0

per_frame_init_1=`
    decay = 0.98;
    vol = bass + mid + treb;
`
per_frame_1=`
    q1 = time;
    q2 = vol * 0.1;
    q3 = time * 5.0;
    q4 = treb_att * 2.0;
`
per_pixel_1=`
    // Basic setup
    float2 center_uv = float2(0.5, 0.5);
    float3 background_color = float3(0.0, 0.0, 0.1); // Dark blue background
    ret = background_color;

    // Pulsing Moon
    float moon_pulse = 1.0 + 0.2 * sin(time * 2.0) * q2;
    float2 moon_uv = uv - center_uv;

    float moon_radius = 0.2 * moon_pulse;
    float moon_dist = length(moon_uv);
    float moon_shape = smoothstep(moon_radius, moon_radius - 0.01, moon_dist);

    float cutout_radius = 0.18 * moon_pulse;
    float2 cutout_offset = float2(0.08 * moon_pulse, 0.0);
    float cutout_dist = length(moon_uv - cutout_offset);
    float cutout_shape = smoothstep(cutout_radius, cutout_radius - 0.01, cutout_dist);

    float final_moon = saturate(moon_shape - cutout_shape);
    float3 moon_color = float3(0.9, 0.9, 0.7);
    ret = lerp(ret, moon_color, final_moon);

    // Swirling, Twinkling Stars
    float2 star_uv = uv;
    float angle = time * 0.1 + (bass_att * 0.05);
    float s = sin(angle);
    float c = cos(angle);
    star_uv -= center_uv;
    star_uv = float2(star_uv.x * c - star_uv.y * s, star_uv.x * s + star_uv.y * c);
    star_uv += center_uv;

    // Create a procedural starfield using a hash function
    float star_brightness = 0.0;
    float3 star_color = float3(1.0, 1.0, 1.0);

    float2 grid = floor(star_uv * 100.0);
    float2 grid_frac = frac(star_uv * 100.0);

    // A simple hash function to generate pseudo-random values
    float hash = frac(sin(dot(grid, float2(12.9898, 78.233))) * 43758.5453);

    // Branchless star logic
    float is_star = step(0.99, hash);
    float star_twinkle = 0.5 + 0.5 * sin(q3 + hash * 100.0) * (1.0 + q4);
    float star_size = 0.01 + hash * 0.02;
    float star_dist = length(grid_frac - float2(0.5, 0.5));
    star_brightness = smoothstep(star_size, 0.0, star_dist) * star_twinkle * is_star;

    // Color twinkling
    float3 twinkle_color = float3(sin(time + hash), sin(time + hash + 2.0), sin(time + hash + 4.0));
    twinkle_color = 0.5 + 0.5 * twinkle_color;
    star_color = lerp(float3(1.0,1.0,1.0), twinkle_color, saturate(q4));

    ret = lerp(ret, star_color, star_brightness);
    ret = saturate(ret);
`

[preset00]
fRating=3.0
fGammaAdj=2.0
fDecay=0.98
fVideoEchoZoom=1.0
fVideoEchoAlpha=0.0
nVideoEchoOrientation=0
nWaveMode=0
bAdditiveWaves=0
bWaveDots=0
bWaveThick=0
bModWaveAlphaByVolume=0
bMaximizeWaveColor=0
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=0
bDarken=0
bSolarize=0
bInvert=0
fWaveAlpha=0.001
fWaveScale=1.002
fWaveSmoothing=0.261
fWaveParam=0.0
fModWaveAlphaStart=0.5
fModWaveAlphaEnd=1.0
fWarpAnimSpeed=1.0
fWarpScale=1.331
fZoomExponent=1.0
fShader=1.0
zoom=1.0
rot=0.0
cx=0.5
cy=0.5
dx=0.0
dy=0.0

per_frame_1=// --- Motion and Segmentation Control ---
per_frame_2=rot = rot + 0.002;
per_frame_3=
per_frame_4=// q1 controls the number of segments.
per_frame_5=q1 = 1 + 30*(0.5 + 0.5*sin(time*0.15));
per_frame_6=
per_frame_7=// q2 controls the transition between smooth and segmented plasma.
per_frame_8=q2 = 0.5 + 0.5*sin(time*0.4);
per_frame_9=
per_frame_10=// Precompute time+rot combinations for performance
per_frame_11=q3 = time*1.2 + rot;
per_frame_12=q4 = time*1.3 + rot;
per_frame_13=q5 = time*1.5 + rot;

per_pixel_1=// --- Adding Segmentation to the Bright Preset ---
per_pixel_2=
per_pixel_3=// 1. Calculate the segmented screen coordinates using q1
per_pixel_4=seg_x = floor(uv.x * q1) / q1;
per_pixel_5=seg_y = floor(uv.y * q1) / q1;
per_pixel_6=
per_pixel_7=// 2. Blend between normal (uv) and segmented (seg) coordinates using q2
per_pixel_8=work_x = lerp(uv.x, seg_x, q2);
per_pixel_9=work_y = lerp(uv.y, seg_y, q2);
per_pixel_10=
per_pixel_11=// 3. Use these final coordinates in the plasma formula that we know works.
per_pixel_12=r = 0.7 + 0.3*sin(work_x*8 + q3);
per_pixel_13=g = 0.7 + 0.3*sin(work_y*8 + q4);
per_pixel_14=b = 0.7 + 0.3*sin((work_x+work_y)*4 + q5);
per_pixel_15=
per_pixel_16=// 4. Apply the final brightness boost
per_pixel_17=boost = 1.2 + 0.8*bass_att;
per_pixel_18=
per_pixel_19=ret = float3(min(r*boost, 1.0), min(g*boost, 1.0), min(b*boost, 1.0));

.custom-file-upload {
display: block;
padding: 10px 20px;
background-color: #4CAF50; /* Green */
color: white;
cursor: pointer;
border: none;
z-index: 5000;
top:10vh;
left:50vh;
position:absolute;
border-radius: 5px;
pointer-events: none;

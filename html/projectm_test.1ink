<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>B3HD • Industrial Control</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', system_ui, sans-serif; background: #111; }

    .panel-container {
      width: 620px;
      height: 620px;
      position: relative;
    }

    .panel-bg {
      width: 100%;
      height: 100%;
      border-radius: 9999px;
      overflow: hidden;
      box-shadow: 0 25px 60px -15px rgb(0 0 0 / 0.7);
      border: 12px solid #374151;
    }

    .panel-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .clickable-button {
      position: absolute;
      background: transparent;
      border: none;
      cursor: pointer;
      z-index: 10;
      transition: transform 0.1s ease, filter 0.1s ease;
    }

    .clickable-button:active {
      transform: scale(0.95);
      filter: brightness(0.8);
    }

    .knob {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 160px;
      height: 160px;
      background: radial-gradient(circle at 40% 30%, #1f2937, #111827 60%, #000);
      border-radius: 9999px;
      box-shadow: 0 0 0 12px #1f2937,
                  inset 0 20px 40px rgba(255,255,255,0.15),
                  0 10px 30px rgba(0,0,0,0.8);
      z-index: 20;
      cursor: grab;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .knob:active { cursor: grabbing; }
    .knob::after {
      content: '';
      width: 18px;
      height: 18px;
      background: #ef4444;
      border-radius: 9999px;
      box-shadow: 0 0 15px #ef4444;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center">

  <div class="panel-container">
    <!-- Generated Panel Background -->
    <div class="panel-bg">
      <img src="./panel-bg.jpg" alt="Industrial Control Panel">
    </div>

    <!-- Interactive Overlay Buttons (positioned over the generated image) -->
    <button onclick="hidePanel()" class="clickable-button" style="top: 18%; left: 22%; width: 18%; height: 11%;"></button>
    <button onclick="lockPreset()" class="clickable-button" style="top: 12%; left: 42%; width: 16%; height: 9%;"></button>
    <button onclick="startChangeSong()" class="clickable-button" style="top: 32%; left: 12%; width: 18%; height: 11%;"></button>
    <button onclick="fullWindow()" class="clickable-button" style="top: 52%; left: 14%; width: 18%; height: 11%;"></button>
    <button onclick="randomPreset()" class="clickable-button" style="top: 32%; right: 14%; width: 18%; height: 11%;"></button>
    <button onclick="randomCustom()" class="clickable-button" style="top: 52%; right: 14%; width: 18%; height: 11%;"></button>

    <!-- Central Draggable Knob -->
    <div id="knob" class="knob"></div>
  </div>

  <button onclick="showPanel()" id="show-btn"
          class="hidden fixed bottom-8 right-8 px-6 py-3 bg-zinc-800 text-white rounded-2xl text-sm border border-white/20">
    Show Controls
  </button>

  <script>
    // Draggable Knob
    const knob = document.getElementById('knob');
    let rot = 0, dragging = false, startAng = 0;

    function angle(e) {
      const r = knob.getBoundingClientRect();
      const cx = r.left + r.width/2;
      const cy = r.top + r.height/2;
      return Math.atan2(e.clientY - cy, e.clientX - cx) * 180 / Math.PI;
    }

    knob.addEventListener('mousedown', e => { dragging = true; startAng = angle(e) - rot; });
    document.addEventListener('mousemove', e => { if(dragging){ rot = angle(e) - startAng; knob.style.transform = `translate(-50%,-50%) rotate(${rot}deg)`; }});
    document.addEventListener('mouseup', () => dragging = false);

    // Touch support
    knob.addEventListener('touchstart', e => { dragging=true; startAng = angle(e.touches[0]) - rot; });
    document.addEventListener('touchmove', e => { if(dragging) { rot = angle(e.touches[0]) - startAng; knob.style.transform=`translate(-50%,-50%) rotate(${rot}deg)`; }});
    document.addEventListener('touchend', () => dragging=false);

    function hidePanel() {
      const p = document.querySelector('.panel-container');
      p.style.transition = 'all 0.3s ease';
      p.style.opacity = '0';
      setTimeout(() => { p.style.display='none'; document.getElementById('show-btn').classList.remove('hidden'); }, 280);
    }
    function showPanel() {
      const p = document.querySelector('.panel-container');
      p.style.display = 'block';
      p.style.opacity = '0';
      setTimeout(() => { p.style.transition='all 0.3s ease'; p.style.opacity='1'; }, 10);
      document.getElementById('show-btn').classList.add('hidden');
    }

    // Wire these to your real B3HD logic
    function startChangeSong() { console.log('%c[B3HD] Start/Change Song', 'color:#f43f5e'); }
    function fullWindow() { console.log('%c[B3HD] Full Window', 'color:#f43f5e'); }
    function randomPreset() { console.log('%c[B3HD] Random Preset', 'color:#f43f5e'); }
    function randomCustom() { console.log('%c[B3HD] Random Custom', 'color:#f43f5e'); }
    function lockPreset() { console.log('%c[B3HD] Lock Preset', 'color:#f43f5e'); }

    // Subtle idle animation on knob
    setTimeout(() => {
      knob.style.transition = 'transform 1.5s cubic-bezier(0.34,1.56,0.64,1)';
      knob.style.transform = `translate(-50%, -50%) rotate(${Math.random()*25 - 12}deg)`;
    }, 1200);
  </script>
</body>
</html>

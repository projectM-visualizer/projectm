document.getElementById("startBtn5").addEventListener('click',function(){
if (window._pmLoading || window._pmLoaded) {
    console.log('projectM module already loading or loaded, skipping duplicate load');
    return;
}
window._pmLoading = true;
let scr=document.createElement("script");
scr.async=true;
scr.charset='utf-8';
scr.type='text/javascript';
scr.defer=true;
// scr.src="https://wasm.noahcohn.com/b3hd/w0-007-mod.1ijs";
scr.src="./pm/projectm-v.026-thread.1ijs";
document.body.appendChild(scr);
setTimeout(function(){
createModule().then(async function(instance) {
Module=instance;
window._pmLoading = false;
window._pmLoaded = true;

Module._init();
updateLayout();
syncModuleSize();
const mcanvas = document.querySelector('#mcanvas');
const startupPaths = await loadStartupApiPresets(5);
if (startupPaths.length > 0) {
    Module.ccall('load_preset_file', null, ['string'], [startupPaths[0]]);
    for (let i = 1; i < startupPaths.length; i++) {
        Module.ccall('add_preset_file', null, ['string'], [startupPaths[i]]);
    }
} else {
    console.warn('No startup API presets loaded');
}
Module._start_render(mcanvas.width, mcanvas.height);
// Background load remaining presets so rendering isn't blocked
// loadRegularMilkPresets();
}).catch(function(err) {
    window._pmLoading = false;
    console.error('projectM module initialization failed:', err);
});
},1000);
});

let viewMode = 'bezel';

// ====== API PRESET HELPERS ======
window.updatePresetDisplay = function(name) {
    if (!name) return;
    const basename = name.split('/').pop();
    const el = document.querySelector('#preset-name');
    if (el) {
        el.textContent = 'Preset: ' + basename;
        window.currentPresetName = basename;
    }
};

function getPresetDir() {
    const el = document.getElementById('presetDir');
    const val = el ? el.innerHTML.trim() : 'default';
    return val === 'default' ? 'any' : val;
}

async function fetchApiPreset(apiBase) {
    const dir = getPresetDir();
    const res = await fetch(`${apiBase}/api/presets/random?dir=${encodeURIComponent(dir)}`);
    if (!res.ok) throw new Error('API error: ' + res.status);
    const data = await res.json();
    if (!data.url || !data.filename || !data.dir) {
        throw new Error('Invalid API response: missing url, filename, or dir');
    }
    const milkRes = await fetch(data.url);
    if (!milkRes.ok) throw new Error('Failed to fetch milk: ' + milkRes.status);
    const buffer = await milkRes.arrayBuffer();
    const bytes = new Uint8ClampedArray(buffer);
    const safeName = data.filename.replace(/[^a-zA-Z0-9._-]/g, '_');
    const vfsPath = `/presets/api_${data.dir}_${safeName}`;
  if (!Module.FS) throw new Error('Module.FS not available');
  Module.FS.writeFile(vfsPath, bytes);
  return { vfsPath, filename: data.filename, dir: data.dir };
}

async function loadStartupApiPresets(count) {
    const apiBase = localStorage.getItem('apiBase') || 'https://storage.noahcohn.com';
    const paths = [];
    for (let i = 0; i < count; i++) {
        try {
            const result = await fetchApiPreset(apiBase);
            paths.push(result.vfsPath);
            console.log('Startup API preset', i, 'loaded:', result.filename);
        } catch (e) {
            console.error('Failed to load startup API preset', i, e);
        }
    }
    return paths;
}


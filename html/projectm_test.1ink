function updateLayout() {
    const mcanvas = document.querySelector('#mcanvas');
    const scanvas = document.querySelector('#scanvas');
    const wrap = document.querySelector('#wrap');
    const contain1 = document.querySelector('#contain1');
    const contain1a = document.querySelector('#contain1a');
    const musicBtn = document.querySelector('#musicBtn');
    const randomPresetBtn = document.querySelector('#randomPresetBtn');
    const fullWindowBtn = document.querySelector('#fullWindowBtn');
    const fullscreenBtn = document.querySelector('#fullscreenBtn');
    const customMilkBtn = document.querySelector('#customMilkBtn');
    const apiRandomPresetBtn = document.querySelector('#apiRandomPresetBtn');
    const flacPlayerBtn = document.querySelector('#flacPlayerBtn');
    const lockPresetBtn = document.querySelector('#lockPresetBtn');
    const pmImages = document.querySelectorAll('#pm');
    const menu = document.querySelector('#menu');

    if (viewMode === 'bezel') {
        // === BEZEL MODE (centered square) ===
        const sz = window.innerHeight;

        if (wrap) {
            wrap.style.width = ''; wrap.style.height = ''; wrap.style.position = '';
            wrap.style.top = ''; wrap.style.left = '';
        }
        if (contain1) {
            contain1.style.width = sz + 'px';
            contain1.style.height = sz + 'px';
            contain1.style.left = 'calc(50vw - ' + (sz / 2) + 'px)';
            contain1.style.top = '0';
            contain1.style.position = 'absolute';
        }
        if (contain1a) contain1a.style.display = 'block';

        mcanvas.style.width = '100%';
        mcanvas.style.height = '100%';
        scanvas.style.width = '100%';
        scanvas.style.height = '100%';

        mcanvas.style.left = '0';
        mcanvas.style.top = '0';
        mcanvas.style.margin = '0';
        mcanvas.style.padding = '0';
        scanvas.style.left = '0';
        scanvas.style.top = '0';
        scanvas.style.margin = '0';
        scanvas.style.padding = '0';

        document.querySelector('#circle').style.display = 'block';
        document.querySelector('#gl').style.display = 'block';
        musicBtn.style.left = '3%';
        musicBtn.style.bottom = '12%';
        randomPresetBtn.style.left = '3%';
        randomPresetBtn.style.bottom = '18%';
        fullWindowBtn.style.left = '3%';
        fullWindowBtn.style.bottom = '24%';
        fullscreenBtn.style.left = '3%';
        fullscreenBtn.style.bottom = '30%';
        customMilkBtn.style.left = '3%';
        customMilkBtn.style.bottom = '36%';
        apiRandomPresetBtn.style.left = '3%';
        apiRandomPresetBtn.style.bottom = '42%';
        flacPlayerBtn.style.left = '3%';
        flacPlayerBtn.style.bottom = '48%';
        lockPresetBtn.style.left = '3%';
        lockPresetBtn.style.bottom = '54%';
        musicBtn.nextElementSibling.style.left = '6%';
        musicBtn.nextElementSibling.style.bottom = '12%';
        randomPresetBtn.nextElementSibling.style.left = '6%';
        randomPresetBtn.nextElementSibling.style.bottom = '18%';
        fullWindowBtn.nextElementSibling.style.left = '6%';
        fullWindowBtn.nextElementSibling.style.bottom = '24%';
        fullscreenBtn.nextElementSibling.style.left = '6%';
        fullscreenBtn.nextElementSibling.style.bottom = '30%';
        customMilkBtn.nextElementSibling.style.left = '6%';
        customMilkBtn.nextElementSibling.style.bottom = '36%';
        apiRandomPresetBtn.nextElementSibling.style.left = '6%';
        apiRandomPresetBtn.nextElementSibling.style.bottom = '42%';
        flacPlayerBtn.nextElementSibling.style.left = '6%';
        flacPlayerBtn.nextElementSibling.style.bottom = '48%';
        lockPresetBtn.nextElementSibling.style.left = '6%';
        lockPresetBtn.nextElementSibling.style.bottom = '54%';
        pmImages.forEach(img => img.style.display = 'block');
        if (menu) menu.style.display = 'block';

        draw();
    } else {
        // === FULL RECTANGULAR MODE ===
        const vw = window.innerWidth;
        const vh = window.innerHeight;

        if (wrap) {
            wrap.style.width = '100vw'; wrap.style.height = '100vh';
            wrap.style.position = 'fixed'; wrap.style.top = '0'; wrap.style.left = '0';
        }
        if (contain1) {
            contain1.style.width = '100vw';
            contain1.style.height = '100vh';
            contain1.style.left = '0';
            contain1.style.top = '0';
            contain1.style.position = 'fixed';
        }
        if (contain1a) contain1a.style.display = 'none';

        mcanvas.style.width = '100vw';
        mcanvas.style.height = '100vh';
        scanvas.style.width = '100vw';
        scanvas.style.height = '100vh';

        mcanvas.style.left = '0';
        mcanvas.style.top = '0';
        mcanvas.style.margin = '0';
        mcanvas.style.padding = '0';
        scanvas.style.left = '0';
        scanvas.style.top = '0';
        scanvas.style.margin = '0';
        scanvas.style.padding = '0';

        document.querySelector('#circle').style.display = 'none';
        document.querySelector('#gl').style.display = 'none';
        musicBtn.style.left = '1%';
        musicBtn.style.bottom = '8%';
        randomPresetBtn.style.left = '1%';
        randomPresetBtn.style.bottom = '12%';
        fullWindowBtn.style.left = '1%';
        fullWindowBtn.style.bottom = '16%';
        fullscreenBtn.style.left = '1%';
        fullscreenBtn.style.bottom = '20%';
        customMilkBtn.style.left = '1%';
        customMilkBtn.style.bottom = '24%';
        apiRandomPresetBtn.style.left = '1%';
        apiRandomPresetBtn.style.bottom = '28%';
        flacPlayerBtn.style.left = '1%';
        flacPlayerBtn.style.bottom = '34%';
        lockPresetBtn.style.left = '1%';
        lockPresetBtn.style.bottom = '40%';
        musicBtn.nextElementSibling.style.left = '4%';
        musicBtn.nextElementSibling.style.bottom = '8%';
        randomPresetBtn.nextElementSibling.style.left = '4%';
        randomPresetBtn.nextElementSibling.style.bottom = '12%';
        fullWindowBtn.nextElementSibling.style.left = '4%';
        fullWindowBtn.nextElementSibling.style.bottom = '16%';
        fullscreenBtn.nextElementSibling.style.left = '4%';
        fullscreenBtn.nextElementSibling.style.bottom = '20%';
        customMilkBtn.nextElementSibling.style.left = '4%';
        customMilkBtn.nextElementSibling.style.bottom = '24%';
        apiRandomPresetBtn.nextElementSibling.style.left = '4%';
        apiRandomPresetBtn.nextElementSibling.style.bottom = '28%';
        flacPlayerBtn.nextElementSibling.style.left = '4%';
        flacPlayerBtn.nextElementSibling.style.bottom = '34%';
        lockPresetBtn.nextElementSibling.style.left = '4%';
        lockPresetBtn.nextElementSibling.style.bottom = '40%';
        pmImages.forEach(img => img.style.display = 'none');
        if (menu) menu.style.display = 'none';
    }
}

// ResizeObserver handles internal canvas resolution and Module window size.
// It fires once immediately on observation, guaranteeing the initial size
// is synced with the final CSS layout before the Emscripten module loads.
const resizeObserver = new ResizeObserver((entries) => {
    for (const entry of entries) {
        const dpr = window.devicePixelRatio || 1;
        const cssWidth = entry.contentRect.width;
        const cssHeight = entry.contentRect.height;
        const w = Math.max(1, Math.round(cssWidth * dpr));
        const h = Math.max(1, Math.round(cssHeight * dpr));

        const mcanvas = document.querySelector('#mcanvas');
        const scanvas = document.querySelector('#scanvas');
        if (!mcanvas || !scanvas) continue;

        mcanvas.width = w;
        mcanvas.height = h;
        scanvas.width = w;
        scanvas.height = h;

        mcanvas.style.width = cssWidth + 'px';
        mcanvas.style.height = cssHeight + 'px';
        scanvas.style.width = cssWidth + 'px';
        scanvas.style.height = cssHeight + 'px';

        if (typeof Module !== 'undefined' && Module._set_window_size) {
            Module._set_window_size(w, h);
        }
        if (typeof Module !== 'undefined' && Module._set_aspect_correction) {
            Module._set_aspect_correction(viewMode === 'bezel');
        }
    }
});

const contain1El = document.querySelector('#contain1');
if (contain1El) {
    resizeObserver.observe(contain1El);
}

async function loadRandomApiPreset() {
    if (typeof Module === 'undefined' || !Module._load_preset_file) {
        console.error('Module not ready');
        return;
    }
    const apiBase = localStorage.getItem('apiBase') || 'https://storage.noahcohn.com';
    try {
        const result = await fetchApiPreset(apiBase);
        Module.ccall('load_preset_file', null, ['string'], [result.vfsPath]);
        console.log('Loaded API preset:', result.filename, 'from', result.dir);
    } catch (e) {
        console.error('Failed to load API preset:', e);
    }
}

document.getElementById("randomPresetBtn").addEventListener('click', function() {
    loadRandomApiPreset();
});

document.getElementById("apiRandomPresetBtn").addEventListener('click', function() {
    loadRandomApiPreset();
});

let isPresetLocked = false;
document.addEventListener('keydown', function(event) {
    if (event.key === ' ' || event.keyCode === 32) {
        event.preventDefault();
        document.getElementById('apiRandomPresetBtn').click();
    }
    if (event.key === 'l' || event.key === 'L' || event.keyCode === 76) {
        document.getElementById('lockPresetBtn').click();
    }
});

document.getElementById("lockPresetBtn").addEventListener('click', function() {
    isPresetLocked = !isPresetLocked;
    const btn = document.getElementById("lockPresetBtn");
    const label = document.getElementById("lockPresetLabel");
    if (isPresetLocked) {
        btn.style.backgroundColor = 'red';
        btn.style.borderColor = 'red';
        if (label) label.textContent = 'Unlock Preset';
    } else {
        btn.style.backgroundColor = 'green';
        btn.style.borderColor = 'green';
        if (label) label.textContent = 'Lock Preset';
    }
    if (typeof Module !== 'undefined' && Module._set_preset_locked) {
        Module._set_preset_locked(isPresetLocked ? 1 : 0);
    } else if (typeof Module !== 'undefined' && Module.ccall) {
        Module.ccall('set_preset_locked', null, ['number'], [isPresetLocked ? 1 : 0]);
    }
    console.log('Preset lock:', isPresetLocked);
});

function enterFullscreen() {
    const elem = document.documentElement;
    if (elem.requestFullscreen) {
        elem.requestFullscreen();
    } else if (elem.webkitRequestFullscreen) {
        elem.webkitRequestFullscreen();
    } else if (elem.msRequestFullscreen) {
        elem.msRequestFullscreen();
    }
}

function exitFullscreen() {
    if (document.exitFullscreen) {
        document.exitFullscreen();
    } else if (document.webkitExitFullscreen) {
        document.webkitExitFullscreen();
    } else if (document.msExitFullscreen) {
        document.msExitFullscreen();
    }
}

function syncModuleSize() {
    const contain1 = document.querySelector('#contain1');
    const mcanvas = document.querySelector('#mcanvas');
    const scanvas = document.querySelector('#scanvas');
    if (!contain1 || !mcanvas || !scanvas || typeof Module === 'undefined') return;
    const rect = contain1.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const w = Math.max(1, Math.round(rect.width * dpr));
    const h = Math.max(1, Math.round(rect.height * dpr));
    mcanvas.width = w;
    mcanvas.height = h;
    scanvas.width = w;
    scanvas.height = h;
    mcanvas.style.width = rect.width + 'px';
    mcanvas.style.height = rect.height + 'px';
    scanvas.style.width = rect.width + 'px';
    scanvas.style.height = rect.height + 'px';
    if (Module._set_window_size) {
        Module._set_window_size(w, h);
    }
    if (Module._set_aspect_correction) {
        Module._set_aspect_correction(viewMode === 'bezel');
    }
}

document.getElementById("fullWindowBtn").addEventListener('click', function() {
    if (viewMode === 'window') {
        viewMode = 'bezel';
    } else {
        viewMode = 'window';
        if (document.fullscreenElement) {
            exitFullscreen();
        }
    }
    updateLayout();
    syncModuleSize();
    if (viewMode === 'bezel') draw();
});

document.getElementById("fullscreenBtn").addEventListener('click', function() {
    if (viewMode === 'fullscreen') {
        viewMode = 'bezel';
        exitFullscreen();
    } else {
        viewMode = 'fullscreen';
        enterFullscreen();
    }
    updateLayout();
    syncModuleSize();
    if (viewMode === 'bezel') draw();
});

document.getElementById("flacPlayerBtn").addEventListener('click', function() {
    const section = document.getElementById('flacPlayerSection');
    const isVisible = section.style.display !== 'none';

    if (isVisible) {
        section.style.display = 'none';
        document.getElementById('flacPlayerBtn').style.borderColor = 'green';
    } else {
        document.getElementById('menu').style.display = 'block';
        section.style.display = 'block';
        document.getElementById('flacPlayerBtn').style.borderColor = 'yellow';
    }
});

document.addEventListener('fullscreenchange', function() {
    if (!document.fullscreenElement && viewMode === 'fullscreen') {
        viewMode = 'window';
    }
    updateLayout();
    // Delay sync to let the browser settle into fullscreen dimensions
    setTimeout(syncModuleSize, 100);
    if (viewMode === 'bezel') draw();
});

// ResizeObserver subsumes viewport resize for the canvases themselves,
// but in bezel mode contain1 has a fixed pixel size derived from
// window.innerHeight, so we still need to recompute layout on resize.
window.addEventListener('resize', () => {
    updateLayout();
    if (viewMode === 'bezel') {
        // Redraw circular bezel overlay to fit new dimensions
        document.querySelector('#di').click();
    }
});

updateLayout();

</script>


</html>

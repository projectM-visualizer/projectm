per_frame_30=dy=0.0012*cos(time*0.170+midsm)
per_frame_31=wave_r=0.55+0.45*sin(q8+0.200); wave_g=0.55+0.45*sin(q8+2.300); wave_b=0.55+0.45*sin(q8+4.400)
per_frame_32=ob_r=0.10+0.25*wave_r; ob_g=0.10+0.25*wave_g; ob_b=0.12+0.25*wave_b; ob_a=0.04+0.04*q7

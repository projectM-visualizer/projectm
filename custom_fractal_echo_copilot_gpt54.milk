per_frame_34=mv_a=0.02+0.06*q12; mv_r=wave_r; mv_g=wave_g; mv_b=wave_b; mv_l=0.65+0.20*q7
per_frame_35=q17=time

warp_1=`float2 uvc=uv-0.5;
warp_2=`float rad=length(uvc);
warp_3=`float ang=atan2(uvc.y,uvc.x);
warp_4=`float segs=max(4.0,q4);
warp_5=`float sector=1.57079633/segs;
warp_6=`float a=ang+q3*1.7+0.12*sin(rad*18.0-q17*(1.0+1.6*q1));
warp_7=`float am=abs(frac(a/sector)-0.5)*sector*2.0;
warp_8=`float rr=rad+q13*0.14*sin(rad*q5*6.0-q17*(1.6+2.4*q1));
warp_9=`rr=rr+q6*0.020*sin(am*segs*4.0+q17*3.0+rad*28.0);
warp_10=`rr=max(0.001,rr);
warp_11=`float tunnel=0.18+0.72/(1.0+(2.3+0.6*q14)*rr);
warp_12=`float sampleAng=am+q3*2.3+0.35*sin(rr*24.0-q17*1.2);
warp_13=`float2 suv=0.5+float2(cos(sampleAng),sin(sampleAng))*tunnel;
warp_14=`suv+=q6*0.012*float2(sin(q17*5.0+rr*36.0+ang*2.0),cos(q17*4.0+rr*31.0-ang*2.0));
warp_15=`float ring=0.5+0.5*cos(rr*(24.0+q5*4.0)-q17*(2.2+2.0*q1));
warp_16=`float spokes=pow(saturate(1.0-abs(sin(am*segs*3.0+q17*0.9))),6.0);
warp_17=`float3 base=tex2D(sampler_main,suv).xyz;
warp_18=`float3 tint=0.55+0.45*cos(float3(q8,q8+2.094,q8+4.188)+rr*3.2+ring*1.6);
warp_19=`ret=base*(0.78+0.22*ring)+tint*(0.10*q1+0.08*spokes+0.06*q6);

comp_1=`float2 d=uv-0.5;
comp_2=`float rad=length(d);
comp_3=`float ang=atan2(d.y,d.x);
comp_4=`float3 src=tex2D(sampler_main,uv).xyz;
comp_5=`float3 blur1=GetBlur1(uv);
comp_6=`float3 blur2=GetBlur2(uv);
comp_7=`float ring=0.5+0.5*cos(rad*(18.0+q5*3.0)-q17*(1.3+1.4*q1)+ang*q4);
comp_8=`float spokes=pow(saturate(1.0-abs(sin(ang*q4*0.5+q17*0.7+rad*6.0))),10.0);
comp_9=`float glow=q7*(0.55+0.45*ring)+q12*spokes;
comp_10=`float3 palette=0.55+0.45*cos(float3(q8+0.4,q8+2.494,q8+4.588)+ring*(1.2+0.4*q15)+ang*0.25);
comp_11=`ret=src*(1.0+q11);
comp_12=`ret+=blur1*(0.22+0.40*q7);
comp_13=`ret+=blur2*(0.10+0.22*q12);
comp_14=`ret+=palette*glow*(0.10+0.08*ring);
comp_15=`ret=saturate(ret);

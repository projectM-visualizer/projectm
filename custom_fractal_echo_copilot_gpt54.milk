per_frame_1=basshit=min(1,0.09*bass+0.13*bass_att)
per_frame_2=midhit=min(1,0.09*mid+0.12*mid_att)
per_frame_3=trebhit=min(1,0.10*treb+0.14*treb_att)
per_frame_4=beatsm=0.86*beatsm+0.14*basshit
per_frame_5=midsm=0.90*midsm+0.10*midhit
per_frame_6=trebsm=0.90*trebsm+0.10*trebhit
per_frame_7=tunspin=tunspin+(0.010+0.022*midsm+0.010*trebsm)/if(above(fps,20),fps,20)
per_frame_8=hspin=hspin+(0.006+0.016*trebsm+0.008*midsm)/if(above(fps,20),fps,20)
per_frame_9=q1=beatsm
per_frame_10=q2=0.5+0.5*sin(time*0.270+beatsm*2.400)
per_frame_11=q3=tunspin
per_frame_12=q4=6+above(midsm,0.45)+above(beatsm,0.72)
per_frame_13=q5=8+12*beatsm+6*midsm
per_frame_14=q6=0.15+0.35*trebsm
per_frame_15=q7=0.20+0.40*midsm+0.35*trebsm
per_frame_16=q8=hspin
per_frame_17=q9=0.006*sin(time*0.230)+0.010*sin(time*0.110+1.300)
per_frame_18=q10=0.006*cos(time*0.190)+0.010*cos(time*0.130+2.000)
per_frame_19=q11=0.08+0.20*midsm+0.14*trebsm
per_frame_20=q12=0.12+0.40*trebsm
per_frame_21=q13=0.12+0.28*beatsm
per_frame_22=q14=0.30+0.20*sin(time*0.170+1.700)
per_frame_23=q15=0.5+0.5*sin(time*0.130+2.100)
per_frame_24=q16=0.04+0.12*midsm+0.10*beatsm
per_frame_25=zoom=1.008+0.010*beatsm+0.005*q2
per_frame_26=rot=0.004*sin(time*0.180)+0.006*midsm
per_frame_27=warp=0.012+0.018*beatsm+0.012*midsm+0.010*trebsm
per_frame_28=cx=0.5+q9; cy=0.5+q10

warp_1=`float2 d=uv-0.5;
warp_2=`float r=length(d);
warp_3=`float a=atan2(d.y,d.x);
warp_4=`r*=1.0+q10;
warp_5=`a+=q12*sin(r*12.0+q1*4.0);
warp_6=`r+=q11*sin(r*30.0-q1*8.0);
warp_7=`float2 coords;
warp_8=`coords.x=cos(a)*r+0.5;
warp_9=`coords.y=sin(a)*r+0.5;
warp_10=`coords-=normalize(d+0.0001)*q13;
warp_11=`ret=tex2D(sampler_main,coords).xyz;
comp_1=`float3 col=tex2D(sampler_main,uv).xyz;
comp_2=`float2 d=uv-0.5;
comp_3=`float r=length(d);
comp_4=`float core=smoothstep(0.25,0.0,r);
comp_5=`float corona=smoothstep(0.6,0.1,r)*q2;
comp_6=`float flash=q14*smoothstep(0.5,0.0,r);
comp_7=`float3 hotcore=float3(1.0,0.95,0.8);
comp_8=`float3 corona1=float3(1.0,0.4,0.05);
comp_9=`float3 corona2=float3(1.0,0.15,0.02);
comp_10=`float3 ejecta=float3(1.0,0.7,0.2);
comp_11=`float bright=dot(col,float3(0.3,0.5,0.2));
comp_12=`float3 outcol=lerp(corona2,corona1,saturate(bright*3.0));
comp_13=`outcol=lerp(outcol,ejecta,saturate(bright*5.0-1.5));
comp_14=`outcol=lerp(outcol,hotcore,saturate(bright*8.0-3.0));
comp_15=`outcol+=flash;
comp_16=`outcol+=core*hotcore*0.5;
comp_17=`outcol+=corona*corona1*0.4;
comp_18=`float vig=smoothstep(0.75,0.35,r);
comp_19=`outcol*=0.6+0.4*vig;
comp_20=`ret=saturate(outcol);

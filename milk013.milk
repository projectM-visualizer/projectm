per_frame_1=q1=time*0.6
per_frame_2=q2=bass_att
per_frame_3=q3=mid_att
per_frame_4=q4=treb_att
per_frame_5=q5=sin(q1)
per_frame_6=q6=cos(q1*0.8)
per_frame_7=q7=bass
per_frame_8=q8=pow(q2,2)
per_frame_9=q9=pow(q4,2)
per_frame_10=q10=q2*0.06
